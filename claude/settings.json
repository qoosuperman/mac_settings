{
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\e]1;⚡ Claude: 需要操作\\a'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '\\e]1;✅ Claude: 完成\\a'"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "enabledPlugins": {
    "figma@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Grep",
      "Glob",
      "LS",
      "MultiEdit",
      "NotebookRead",
      "NotebookEdit",
      "TodoRead",
      "TodoWrite",
      "WebSearch",
      "WebFetch",
      "Bash(grep *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git fetch *)",
      "Bash(git pull *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(gh *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(chmod *)",
      "Bash(echo *)",
      "Bash(brew *)",
      "Bash(node *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(ruby *)",
      "Bash(bundle *)",
      "Bash(python *)",
      "Bash(pip *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(find *)",
      "Bash(cd *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(mv *)",
      "Bash(kubectl *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  }
}
